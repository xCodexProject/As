-- ============================================================
-- SMART SHOP SCRIPT (GET_LIST + BUY)
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RequestShop = ReplicatedStorage
    :WaitForChild("Remotes")
    :WaitForChild("TutorialRemotes")
    :WaitForChild("RequestShop")

local State = {
    SelectedItem = nil,
    Amount = 1,
    Buying = false,
    ShopList = {}
}

-- ============================================================
-- LOAD FLUENT UI
-- ============================================================

local Fluent = loadstring(game:HttpGet(
    "https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"
))()

local Window = Fluent:CreateWindow({
    Title = "Smart Shop",
    Size = UDim2.fromOffset(520, 400),
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tab = Window:AddTab({ Title = "Shop", Icon = "shopping-cart" })

-- ============================================================
-- GET SHOP LIST
-- ============================================================

local function LoadShopList()

    local success, result = pcall(function()
        return RequestShop:InvokeServer("GET_LIST")
    end)

    if success and typeof(result) == "table" then
        State.ShopList = result
        return result
    else
        warn("Gagal ambil list:", result)
        return {}
    end
end

local ShopItems = LoadShopList()

-- Extract nama item dari table
local ItemNames = {}

for _, item in pairs(ShopItems) do
    if typeof(item) == "table" and item.Name then
        table.insert(ItemNames, item.Name)
    elseif typeof(item) == "string" then
        table.insert(ItemNames, item)
    end
end

-- ============================================================
-- UI
-- ============================================================

local Dropdown = Tab:AddDropdown("ItemDropdown", {
    Title = "Pilih Item",
    Values = ItemNames,
    Default = ItemNames[1],
    Callback = function(val)
        State.SelectedItem = val
    end,
})

State.SelectedItem = ItemNames[1]

Tab:AddSlider("AmountSlider", {
    Title = "Jumlah (Max 99)",
    Min = 1,
    Max = 99,
    Default = 1,
    Rounding = 0,
    Callback = function(val)
        State.Amount = val
    end,
})

local Status = Tab:AddParagraph({
    Title = "Status",
    Content = "Siap..."
})

local function SetStatus(text)
    Status:SetContent(text)
end

-- ============================================================
-- BUY BUTTON
-- ============================================================

Tab:AddButton({
    Title = "Beli Item",
    Callback = function()

        if State.Buying then return end
        if not State.SelectedItem then return end

        State.Buying = true

        task.spawn(function()

            for i = 1, State.Amount do

                local success, err = pcall(function()
                    return RequestShop:InvokeServer(
                        "BUY",
                        State.SelectedItem,
                        1
                    )
                end)

                if not success then
                    warn(err)
                    SetStatus("Error saat beli ❌")
                    break
                end

                SetStatus("Membeli " .. i .. "/" .. State.Amount)
                task.wait(0.2)
            end

            SetStatus("Selesai ✅")
            State.Buying = false

        end)

    end,
})

-- Reload Button
Tab:AddButton({
    Title = "Refresh Shop List",
    Callback = function()

        local newList = LoadShopList()
        local newNames = {}

        for _, item in pairs(newList) do
            if typeof(item) == "table" and item.Name then
                table.insert(newNames, item.Name)
            elseif typeof(item) == "string" then
                table.insert(newNames, item)
            end
        end

        Dropdown:SetValues(newNames)
        SetStatus("List diperbarui ✅")
    end,
})

Window:SelectTab(1)
