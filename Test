-- ============================================================
-- AUTO BELI BIBIT (REQUESTSHOP VERSION)
-- ReplicatedStorage > Remotes > TutorialRemotes > RequestShop
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

-- ============================================================
-- AMBIL REMOTE
-- ============================================================

local RequestShop = ReplicatedStorage
    :WaitForChild("Remotes")
    :WaitForChild("TutorialRemotes")
    :WaitForChild("RequestShop")

-- ============================================================
-- STATE
-- ============================================================

local State = {
    SelectedSeed = "Bibit Jagung",
    Amount = 1,
    Buying = false
}

-- ============================================================
-- LOAD FLUENT UI
-- ============================================================

local Fluent = loadstring(game:HttpGet(
    "https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"
))()

local Window = Fluent:CreateWindow({
    Title = "Shop Bibit",
    SubTitle = "RequestShop Remote",
    TabWidth = 160,
    Size = UDim2.fromOffset(500, 350),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" }),
}

-- ============================================================
-- UI
-- ============================================================

Tabs.Main:AddDropdown("SeedDropdown", {
    Title = "Pilih Bibit",
    Values = {"Bibit Jagung", "Bibit Padi"},
    Default = "Bibit Jagung",
    Callback = function(val)
        State.SelectedSeed = val
    end,
})

Tabs.Main:AddSlider("AmountSlider", {
    Title = "Jumlah (Max 99)",
    Min = 1,
    Max = 99,
    Default = 1,
    Rounding = 0,
    Callback = function(val)
        State.Amount = val
    end,
})

local Status = Tabs.Main:AddParagraph({
    Title = "Status",
    Content = "Siap..."
})

local function SetStatus(text)
    Status:SetContent(text)
end

Tabs.Main:AddButton({
    Title = "Beli Bibit",
    Description = "Kirim request sesuai jumlah",
    Callback = function()

        if State.Buying then return end
        State.Buying = true

        SetStatus("Memproses pembelian...")

        task.spawn(function()

            -- Kirim 1x request (tidak spam loop)
            pcall(function()
                -- FORMAT UMUM:
                -- RequestShop:FireServer("Bibit Jagung", 10)

                RequestShop:FireServer(State.SelectedSeed, State.Amount)
            end)

            task.wait(0.5)

            SetStatus("Selesai membeli " .. State.Amount .. " " .. State.SelectedSeed .. " ✅")
            State.Buying = false

        end)

    end,
})

Fluent:Notify({
    Title = "Loaded ✅",
    Content = "Shop Bibit Siap Digunakan",
    Duration = 4
})

Window:SelectTab(1)
