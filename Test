-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RequestShop = ReplicatedStorage
    :WaitForChild("Remotes")
    :WaitForChild("TutorialRemotes")
    :WaitForChild("RequestShop")

local State = {
    SelectedSeed = "Bibit Padi",
    Amount = 1,
    Buying = false
}

local Fluent = loadstring(game:HttpGet(
    "https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"
))()

local Window = Fluent:CreateWindow({
    Title = "Shop Bibit",
    Size = UDim2.fromOffset(500, 350),
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tab = Window:AddTab({ Title = "Main", Icon = "home" })

Tab:AddDropdown("SeedDropdown", {
    Title = "Pilih Bibit",
    Values = {"Bibit Jagung", "Bibit Padi"},
    Default = "Bibit Padi",
    Callback = function(val)
        State.SelectedSeed = val
    end,
})

Tab:AddSlider("AmountSlider", {
    Title = "Jumlah (Max 99)",
    Min = 1,
    Max = 99,
    Default = 1,
    Rounding = 0,
    Callback = function(val)
        State.Amount = val
    end,
})

local Status = Tab:AddParagraph({
    Title = "Status",
    Content = "Siap..."
})

local function SetStatus(text)
    Status:SetContent(text)
end

Tab:AddButton({
    Title = "Beli Bibit",
    Callback = function()

        if State.Buying then return end
        State.Buying = true

        task.spawn(function()

            for i = 1, State.Amount do

                local success, err = pcall(function()
                    return RequestShop:InvokeServer(
                        "BUY",
                        State.SelectedSeed,
                        1 -- selalu 1
                    )
                end)

                if not success then
                    warn(err)
                    SetStatus("Error saat membeli ❌")
                    break
                end

                SetStatus("Membeli " .. i .. "/" .. State.Amount)

                task.wait(0.2) -- delay aman
            end

            SetStatus("Selesai ✅")
            State.Buying = false

        end)

    end,
})

Window:SelectTab(1)
