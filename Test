-- ============================================================
-- AUTO BELI BIBIT (InvokeServer Version)
-- Format: InvokeServer("BUY", "Bibit Padi", 1)
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

-- ============================================================
-- AMBIL REMOTE FUNCTION
-- ============================================================

local RequestShop = ReplicatedStorage
    :WaitForChild("Remotes")
    :WaitForChild("TutorialRemotes")
    :WaitForChild("RequestShop")

-- ============================================================
-- STATE
-- ============================================================

local State = {
    SelectedSeed = "Bibit Jagung",
    Amount = 1,
    Buying = false
}

-- ============================================================
-- LOAD FLUENT UI
-- ============================================================

local Fluent = loadstring(game:HttpGet(
    "https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"
))()

local Window = Fluent:CreateWindow({
    Title = "Shop Bibit",
    SubTitle = "InvokeServer Mode",
    TabWidth = 160,
    Size = UDim2.fromOffset(500, 350),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" }),
}

-- ============================================================
-- UI
-- ============================================================

Tabs.Main:AddDropdown("SeedDropdown", {
    Title = "Pilih Bibit",
    Values = {"Bibit Jagung", "Bibit Padi"},
    Default = "Bibit Jagung",
    Callback = function(val)
        State.SelectedSeed = val
    end,
})

Tabs.Main:AddSlider("AmountSlider", {
    Title = "Jumlah (Max 99)",
    Min = 1,
    Max = 99,
    Default = 1,
    Rounding = 0,
    Callback = function(val)
        State.Amount = val
    end,
})

local Status = Tabs.Main:AddParagraph({
    Title = "Status",
    Content = "Siap..."
})

local function SetStatus(text)
    Status:SetContent(text)
end

Tabs.Main:AddButton({
    Title = "Beli Bibit",
    Description = "InvokeServer BUY",
    Callback = function()

        if State.Buying then return end
        State.Buying = true

        SetStatus("Memproses pembelian...")

        task.spawn(function()

            local success, result = pcall(function()
                return RequestShop:InvokeServer(
                    "BUY",
                    State.SelectedSeed,
                    State.Amount
                )
            end)

            if success then
                SetStatus("Berhasil beli "
                    .. State.Amount .. " "
                    .. State.SelectedSeed .. " ✅")
            else
                SetStatus("Gagal membeli ❌")
                warn(result)
            end

            State.Buying = false

        end)

    end,
})

Fluent:Notify({
    Title = "Loaded ✅",
    Content = "Shop Bibit Siap Digunakan",
    Duration = 4
})

Window:SelectTab(1)
